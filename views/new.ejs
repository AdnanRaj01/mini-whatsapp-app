<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Chat</title>
</head>
<body>
    <h3>Create New Chat..</h3>
    <form action="/chats" method="POST">
        <input type="text" name="from" placeholder="Who are you?"><br><br>
        <input type="text" name="to" placeholder="add receiver name"><br><br>
        <textarea name="message" placeholder="Write your message here..."></textarea><br>
        <button type="submit">Create Chat</button>
    </form>
</body>
</html>